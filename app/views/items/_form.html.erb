<%= form_with model: item, local: true do |f| %>

  <%= f.label :title %>
  <%= f.text_field :title %>

  <%= f.label :description %>
  <%= f.text_area :description %>

  <%= f.label :status %>
  <%= f.select :status, Item.statuses.keys %>

  <%= f.label :is_resolved %>
  <%= f.check_box :is_resolved %>

  <%= f.label :image %>
  <%= f.file_field :image %>

  <%= f.submit %>
<% end %>